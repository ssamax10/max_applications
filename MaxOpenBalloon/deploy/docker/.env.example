POSTGRES_DB=maxopenballoon
POSTGRES_USER=max
POSTGRES_PASSWORD=change_me
POSTGRES_PORT=5432

MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=change_me
MINIO_API_PORT=9010
MINIO_CONSOLE_PORT=9011

# Production OIDC settings (used by Helm deployments)
OIDC_ISSUER=https://auth.edge.example.com/application/o/maxopenballoon/
OIDC_JWKS_URL=
OIDC_AUDIENCE=
AUTH_REQUIRED=true
TENANT_CLAIM=tenant_id
ALLOW_TENANT_HEADER_FALLBACK=false
CORS_ALLOW_ORIGINS=http://localhost:5173
AUTHENTIK_SECRET_KEY=change_me_authentik_secret
OPENFGA_URL=http://openfga:8080
OPENFGA_PORT=8081
AUTHENTIK_PORT=19000
REDIS_PORT=6379
FRONTEND_PORT=5173
DRAWING_SERVICE_PORT=18001
GEOMETRY_SERVICE_PORT=18002
BALLOON_SERVICE_PORT=18003
AI_SERVICE_PORT=18004
MCP_SERVICE_PORT=18005
REVISION_SERVICE_PORT=18006
DWG_TRANSLATION_SERVICE_PORT=18007
DWG_TRANSLATION_PUBLIC_BASE_URL=http://localhost:18007
DWG_CONVERSION_ENGINE=qcad
QCAD_CMD=/usr/bin/qcad
QCAD_SCRIPT_PATH=/app/app/scripts/qcad_dwg_to_pdf.js
CONVERSION_TIMEOUT_SECONDS=600
OTEL_EXPORTER_OTLP_ENDPOINT=

VITE_DRAWING_API_BASE=http://localhost:18001
VITE_GEOMETRY_API_BASE=http://localhost:18002
VITE_BALLOON_API_BASE=http://localhost:18003
VITE_AI_API_BASE=http://localhost:18004
VITE_MCP_API_BASE=http://localhost:18005
VITE_REVISION_API_BASE=http://localhost:18006
VITE_DWG_TRANSLATION_API_BASE=http://localhost:18007
VITE_OIDC_ISSUER=https://auth.edge.example.com/application/o/maxopenballoon/
VITE_OIDC_CLIENT_ID=maxopenballoon-frontend
VITE_OIDC_REDIRECT_URI=http://localhost:5173
VITE_OIDC_SCOPE=openid profile email oidc-tenant_id
VITE_OIDC_AUTHORIZATION_ENDPOINT=
# For dev: use Vite proxy to avoid CORS, e.g. http://localhost:5173/authentik/application/o/token/
# For production: use direct Authentik URL or leave empty to use OIDC discovery
VITE_OIDC_TOKEN_ENDPOINT=
VITE_TENANT_CLAIM=tenant_id

# OIDC proxy target for Vite dev server (dev only; not used in production builds)
# Set this to your Authentik server URL when using the Vite proxy for token exchanges
OIDC_PROXY_TARGET=https://apps.maxautocables.com
